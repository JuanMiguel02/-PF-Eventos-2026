<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="lospolimorficos.boletopolis.viewController.CreacionRecintoController">

    <!-- TOP -->
    <top>
        <VBox spacing="10" alignment="CENTER">
            <Label text="Crear Recinto" style="-fx-font-size: 20px;" />

            <HBox spacing="10" alignment="CENTER">
                <TextField fx:id="txtNombre" promptText="Nombre"/>
                <TextField fx:id="txtDireccion" promptText="Dirección"/>
                <ComboBox fx:id="cmbCiudad" promptText="Ciudad"/>
                <ComboBox fx:id="cmbEscenario" promptText="Escenario"/>
                <ComboBox fx:id="cmbPlantillas" promptText="Plantilla"/>
            </HBox>
        </VBox>
    </top>

    <!-- CENTRO: MAPA -->
    <center>
        <ScrollPane pannable="true" fx:id="scrollPane">
            <content>
                <AnchorPane fx:id="panelMapa" prefWidth="1000" prefHeight="800"
                      style="-fx-border-color: black; -fx-background-color: #f4f4f4;"/>
            </content>
        </ScrollPane>
    </center>

    <!-- DERECHA: CONFIG ZONA -->
    <right>
        <VBox spacing="10" prefWidth="250" style="-fx-padding: 10;">

            <Label text="Agregar Zona" style="-fx-font-size: 16px;" />

            <ComboBox fx:id="cmbPosicionZona" promptText="Posición"/>
            <ComboBox fx:id="cmbTipoZona" promptText="Tipo"/>

            <TextField fx:id="txtFilas" promptText="Filas"/>
            <TextField fx:id="txtColumnas" promptText="Columnas"/>
            <TextField fx:id="txtPrecio" promptText="Precio"/>

            <Button text="Agregar Zona" onAction="#agregarZona"/>

        </VBox>
    </right>

    <!-- BOTTOM -->
    <bottom>
        <HBox alignment="CENTER" spacing="20" style="-fx-padding: 10;">
            <Button text="Crear Recinto" onAction="#crearRecinto"/>
        </HBox>
    </bottom>

</BorderPane>