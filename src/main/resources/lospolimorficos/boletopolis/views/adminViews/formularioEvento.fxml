<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" stylesheets="@../../styles/dashboardAdmin.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lospolimorficos.boletopolis.viewController.FormularioEventoController">
   <styleClass>
      <String fx:value="white-bg" />
      <String fx:value="shadow" />
   </styleClass>
   <children>
      <VBox layoutX="20.0" layoutY="20.0" prefWidth="560.0" spacing="15.0">
         <children>
            <Label style="-fx-font-size: 20; -fx-font-weight: bold;" text="Información del Evento" />
            <GridPane hgap="10.0" vgap="10.0">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="250.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <Label text="Nombre:" />
                  <TextField fx:id="txtNombre" GridPane.columnIndex="1" />
                  <Label text="Descripción:" GridPane.rowIndex="1" />
                  <TextField fx:id="txtDescripcion" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <Label text="Ciudad:" GridPane.rowIndex="2" />
                  <ComboBox fx:id="cmbCiudad" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  <Label text="Recinto:" GridPane.rowIndex="3" />
                  <ComboBox fx:id="cmbRecinto" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                  <Label text="Fecha y Hora:" GridPane.rowIndex="4" />
                  <HBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="4">
                     <children>
                        <DatePicker fx:id="dpFecha" prefWidth="150.0" />
                        <TextField fx:id="txtHora" prefWidth="80.0" promptText="HH:mm" />
                     </children>
                  </HBox>
                  <Label text="Tipo de Evento:" GridPane.rowIndex="5" />
                  <ComboBox fx:id="cmbTipoEvento" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="5" />
               </children>
            </GridPane>
            <HBox spacing="20.0">
               <children>
                  <VBox spacing="10.0">
                     <children>
                        <Label text="Imagen del Evento:" />
                        <Button mnemonicParsing="false" onAction="#seleccionarImagen" text="Seleccionar Imagen" />
                     </children>
                  </VBox>
                  <ImageView fx:id="ivImagen" fitHeight="100.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true">
                     <styleClass>
                        <String fx:value="shadow" />
                     </styleClass>
                  </ImageView>
               </children>
            </HBox>
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#cancelar" prefWidth="100.0" styleClass="clear-btn" text="Cancelar" />
                  <Button mnemonicParsing="false" onAction="#guardar" prefWidth="100.0" styleClass="add-btn" text="Guardar" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
