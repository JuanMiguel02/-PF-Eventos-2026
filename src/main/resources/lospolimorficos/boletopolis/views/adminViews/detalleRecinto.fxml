<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lospolimorficos.boletopolis.viewController.DetalleRecintoController">
   <children>
      <VBox spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#regresar" text="Regresar" />
                  <Label fx:id="lblTitulo" text="Detalles del Recinto">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            <HBox spacing="20.0" VBox.vgrow="ALWAYS">
               <children>
                  <VBox prefWidth="300.0" spacing="10.0" styleClass="white-bg, shadow" stylesheets="@../../styles/dashboardAdmin.css">
                     <children>
                        <Label text="Información General">
                           <font>
                              <Font name="System Bold" size="16.0" />
                           </font>
                        </Label>
                        <GridPane vgap="10.0">
                          <columnConstraints>
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0" />
                          </columnConstraints>
                          <rowConstraints>
                            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                              <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                          </rowConstraints>
                           <children>
                              <Label text="Nombre:" />
                              <Label fx:id="lblNombre" text="-" GridPane.columnIndex="1" />
                              <Label text="Ciudad:" GridPane.rowIndex="1" />
                              <Label fx:id="lblCiudad" text="-" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                              <Label text="Dirección:" GridPane.rowIndex="2" />
                              <Label fx:id="lblDireccion" text="-" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                              <Label text="Capacidad:" GridPane.rowIndex="3" />
                              <Label fx:id="lblCapacidad" text="-" GridPane.rowIndex="3" GridPane.columnIndex="1" />
                           </children>
                        </GridPane>
                        <Separator prefWidth="200.0" />
                        <Label text="Zonas">
                           <font>
                              <Font name="System Bold" size="14.0" />
                           </font>
                        </Label>
                        <TableView fx:id="tblZonas" prefHeight="200.0" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="colZonaNombre" prefWidth="100.0" text="Nombre" />
                            <TableColumn fx:id="colZonaCapacidad" prefWidth="75.0" text="Cap." />
                              <TableColumn fx:id="colZonaPrecio" prefWidth="75.0" text="Precio" />
                          </columns>
                        </TableView>
                        <HBox spacing="10.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#eliminarZona" styleClass="delete-btn" text="Eliminar Zona" />
                              <Button mnemonicParsing="false" onAction="#actualizarZona" styleClass="update-btn" text="Actualizar" />
                           </children>
                        </HBox>
                     </children>

                  </VBox>
                  <VBox spacing="10.0" HBox.hgrow="ALWAYS" styleClass="white-bg, shadow" stylesheets="@../../styles/dashboardAdmin.css">
                     <children>
                        <Label text="Mapa del Recinto">
                           <font>
                              <Font name="System Bold" size="16.0" />
                           </font>
                        </Label>
                        <AnchorPane fx:id="panelMapa" prefHeight="400.0" prefWidth="500.0" style="-fx-background-color: #f4f4f4; -fx-border-color: #ccc;" VBox.vgrow="ALWAYS" />
                     </children>

                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
