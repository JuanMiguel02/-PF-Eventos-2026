<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" prefHeight="700.0" prefWidth="1000.0" stylesheets="@../../styles/dashboardAdmin.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lospolimorficos.boletopolis.viewController.DetalleEventoController">
   <content>
      <AnchorPane prefWidth="980.0">
         <children>
            <VBox layoutX="20.0" layoutY="20.0" prefWidth="940.0" spacing="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0">
               <children>
                  <HBox spacing="30.0">
                     <children>
                        <VBox prefWidth="300.0" spacing="15.0">
                           <styleClass>
                              <String fx:value="white-bg" />
                              <String fx:value="shadow" />
                           </styleClass>
                           <children>
                              <ImageView fx:id="ivEvento" fitHeight="200.0" fitWidth="280.0" pickOnBounds="true" preserveRatio="true" />
                              <GridPane hgap="10.0" vgap="10.0">
                                <columnConstraints>
                                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0" />
                                </columnConstraints>
                                <rowConstraints>
                                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                </rowConstraints>
                                 <children>
                                    <Label text="Estado:" />
                                    <ComboBox fx:id="cmbEstado" prefWidth="150.0" GridPane.columnIndex="1" />
                                    <Label text="Nombre:" GridPane.rowIndex="1" />
                                    <TextField fx:id="txtNombre" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                    <Label text="Fecha/Hora:" GridPane.rowIndex="2" />
                                    <TextField fx:id="txtFecha" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                    <Label text="Descripción:" GridPane.rowIndex="3" />
                                    <TextArea fx:id="txtDescripcion" prefHeight="60.0" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                 </children>
                              </GridPane>
                              <HBox alignment="CENTER" spacing="10.0">
                                 <children>
                                    <Button mnemonicParsing="false" onAction="#actualizarInformacion" styleClass="update-btn" text="Actualizar Info" />
                                 </children>
                              </HBox>
                              <Separator prefWidth="200.0" />
                              <Label style="-fx-font-weight: bold;" text="Ocupación por Zonas" />
                              <TableView fx:id="tblZonas" prefHeight="200.0" prefWidth="280.0">
                                <columns>
                                  <TableColumn fx:id="colZonaNombre" prefWidth="120.0" text="Zona" />
                                  <TableColumn fx:id="colOcupacion" prefWidth="80.0" text="Ocupación" />
                                  <TableColumn fx:id="colZonaCapacidad" prefWidth="80.0" text="Capacidad" />
                                </columns>
                              </TableView>
                           </children>
                           <padding>
                              <javafx.geometry.Insets bottom="10.0" left="10.0" right="10.0" top="10.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" />
                           </padding>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS">
                           <styleClass>
                              <String fx:value="white-bg" />
                              <String fx:value="shadow" />
                           </styleClass>
                           <children>
                              <Label style="-fx-font-size: 18; -fx-font-weight: bold;" text="Mapa del Recinto" />
                              <ScrollPane fitToHeight="true" fitToWidth="true" prefHeight="500.0" styleClass="white-bg">
                                 <content>
                                    <AnchorPane fx:id="panelMapa" prefHeight="1000.0" prefWidth="1000.0" style="-fx-background-color: #f4f4f4;" />
                                 </content>
                              </ScrollPane>
                           </children>
                           <padding>
                              <javafx.geometry.Insets bottom="10.0" left="10.0" right="10.0" top="10.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" />
                           </padding>
                        </VBox>
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </AnchorPane>
   </content>
</ScrollPane>
